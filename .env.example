# PostgreSQL connection for Prisma (local or hosted).
# Example: postgresql://USER:PASSWORD@localhost:5432/agenticforce?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agenticforce?schema=public"

