# PostgreSQL connection for Prisma (local or hosted).
# Example: postgresql://USER:PASSWORD@localhost:5432/agenticforce?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agenticforce?schema=public"

# LLM (optional — if unset, agent stages fall back to placeholder artifacts)
# LLM_PROVIDER=auto
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Image generation (optional — Visual Assets in Studio)
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_IMAGE_SIZE=1024x1024
# GEMINI_API_KEY=   # or GOOGLE_API_KEY
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# STORAGE_ROOT=     # default: ./storage — generated files under storage/visual-assets/
