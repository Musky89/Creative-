# =============================================================================
# AgenticForce — environment template
# Copy to .env and edit. See docs/LOCAL_DEV.md for first-time bring-up.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED FOR APP BOOT (orchestrator, Studio, Prisma)
# -----------------------------------------------------------------------------
# PostgreSQL connection string. Must start with postgresql:// or postgres://
#
# If missing or wrong:
#   - prisma migrate / any DB query fails
#   - Dashboard and most pages show "Database unreachable" (dev) or 500
#   - npm run preflight fails at DB check
#
# You always need *some* Postgres URL — the app does not run without a database.
# For testing without installing Postgres on your machine, use a free hosted instance
# (e.g. Neon, Supabase, Railway) and paste its connection string here — no Docker required.
#
# Docker Compose (optional, local): docker compose up -d
#   Default URL matching docker-compose.yml:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agenticforce?schema=public"

# -----------------------------------------------------------------------------
# REQUIRED FOR REAL LLM OUTPUT (not placeholders)
# -----------------------------------------------------------------------------
# Without at least one of these, STRATEGY / CONCEPT / COPY / REVIEW / IDENTITY
# agents persist placeholder artifacts (labeled in JSON) or skip LLM with error.
#
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
#
# Optional model overrides:
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# LLM_PROVIDER=auto

# -----------------------------------------------------------------------------
# REQUIRED FOR IMAGE GENERATION (Studio → Generate visual asset)
# -----------------------------------------------------------------------------
# GENERIC target uses OpenAI first, else Gemini.
#
# Without keys:
#   - generateVisualAssetFromPromptPackage fails with a clear error
#   - VisualAsset row may be created with status FAILED
#
# OPENAI_API_KEY=sk-...          # DALL·E when using GPT_IMAGE or GENERIC
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_IMAGE_SIZE=1024x1024
#
# GEMINI_API_KEY=...             # or GOOGLE_API_KEY=...
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
#
# Optional vision evaluation (after image completes):
# OPENAI_VISION_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# STORAGE (recommended for any visual asset testing)
# -----------------------------------------------------------------------------
# Absolute or relative path. Generated files: {STORAGE_ROOT}/visual-assets/
# If unset, defaults to ./storage under the process cwd.
#
# If directory is not writable:
#   - image save fails; asset marked FAILED
#
# STORAGE_ROOT=./storage

# -----------------------------------------------------------------------------
# DEPLOYMENT / STRICTNESS (optional)
# -----------------------------------------------------------------------------
# Fail production boot if env is incomplete (see src/server/env/deployment-env.ts)
# AGENTICFORCE_STRICT_ENV=1
#
# Fail boot if no image provider keys
# AGENTICFORCE_REQUIRE_IMAGE_GEN=1
#
# Skip instrumentation env assert (CI build-only images, broken local experiments)
# AGENTICFORCE_SKIP_ENV_VALIDATION=1
#
# Base URL for scripts that probe HTTP (e.g. qa:bootstrap optional health check)
# APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# CREATIVE TESTING LAB + PRODUCTION ENGINE (FAL live generation)
# -----------------------------------------------------------------------------
# Creative Testing Lab → Generate uses fal.ai server-side.
# FAL_KEY=...

# -----------------------------------------------------------------------------
# STANDALONE AGENTIC OS (greenfield module — see docs/plans/standalone-agentic-os.md)
# -----------------------------------------------------------------------------
# When unset: /standalone-agentic-os and /api/standalone-agentic-os/* return 404.
# STANDALONE_AGENTIC_OS_ENABLED=1

# -----------------------------------------------------------------------------
# AD CORPUS INGESTION (isolated — see docs/ad-corpus/ARCHITECTURE.md)
# -----------------------------------------------------------------------------
# When unset: /ad-corpus-ingestion returns 404. Use only with licensed / cleared data sources.
# AD_CORPUS_INGESTION_ENABLED=1
