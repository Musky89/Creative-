{
  "name": "agenticforce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:docker": "docker compose --profile dev-server up --build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "env:check": "npx --yes tsx scripts/check-env.ts",
    "qa:bootstrap": "npx --yes tsx scripts/private-dev-qa-bootstrap.ts",
    "preflight": "npx --yes tsx scripts/preflight-dev.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.4.0",
    "jpeg-js": "^0.4.4",
    "jszip": "^3.10.1",
    "next": "^15.2.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pngjs": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx --yes tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
