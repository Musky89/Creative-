// AgenticForce — core domain schema (PostgreSQL)
// Workflow engine, review gating, and agent execution history.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum WorkflowStage {
  BRIEF_INTAKE
  STRATEGY
  CONCEPTING
  VISUAL_DIRECTION
  COPY_DEVELOPMENT
  REVIEW
  EXPORT
}

enum TaskStatus {
  PENDING
  READY
  RUNNING
  AWAITING_REVIEW
  REVISE_REQUIRED
  COMPLETED
  FAILED
}

enum AgentType {
  STRATEGIST
  CREATIVE_DIRECTOR
  ART_DIRECTOR
  COPYWRITER
  BRAND_GUARDIAN
}

enum ArtifactType {
  /// Structured confirmation of brief intake (orchestrator-owned shape until agents exist).
  INTAKE_SUMMARY
  STRATEGY
  CONCEPT
  /// Structured art direction for future image/video/logo pipelines (pre-generation).
  VISUAL_SPEC
  COPY
  REVIEW_REPORT
  EXPORT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

/// Recorded when review resolves an artifact (creative memory lite).
enum ArtifactOutcomeType {
  APPROVED
  REVISED
  REJECTED
}

/// Brand Operating System — language vocabulary register.
enum VocabularyStyle {
  SIMPLE
  ELEVATED
  TECHNICAL
  POETIC
  MIXED
}

/// Brand Operating System — typical sentence construction.
enum SentenceStyle {
  SHORT
  MEDIUM
  LONG
  VARIED
}

/// Brand Operating System — primary emotional register.
enum PrimaryEmotion {
  ASPIRATION
  TRUST
  DESIRE
  URGENCY
  CALM
  BOLD
}

/// Brand Operating System — persuasion mode.
enum PersuasionStyle {
  SUBTLE
  DIRECT
  STORY_LED
  PROOF_LED
}

/// Class of engagement / template used to instantiate work from a Brief.
enum ServiceBlueprintTemplateType {
  FULL_PIPELINE
  CAMPAIGN_SPRINT
  RETAINER_MONTHLY
  CUSTOM
}

// ---------------------------------------------------------------------------
// Client & brand
// ---------------------------------------------------------------------------

model Client {
  id        String   @id @default(cuid())
  name      String
  industry  String
  createdAt DateTime @default(now())

  brandBible             BrandBible?
  serviceBlueprint       ServiceBlueprint?
  briefs                 Brief[]
  frameworkPerformances  FrameworkPerformance[]
  artifactOutcomes       ArtifactOutcome[]
}

/// One canonical Brand Bible per client (1:1).
model BrandBible {
  id        String @id @default(cuid())
  clientId  String @unique
  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  positioning    String @db.Text
  targetAudience String @db.Text
  toneOfVoice    String @db.Text

  messagingPillars    Json
  visualIdentity      Json
  channelGuidelines   Json
  mandatoryInclusions Json
  thingsToAvoid       Json

  /// Brand Operating System — language rules
  vocabularyStyle   VocabularyStyle @default(SIMPLE)
  sentenceStyle     SentenceStyle   @default(MEDIUM)
  bannedPhrases     Json            @default("[]")
  preferredPhrases  Json            @default("[]")
  signaturePatterns Json            @default("[]")

  /// Brand Operating System — emotional profile
  primaryEmotion             PrimaryEmotion @default(TRUST)
  emotionalToneDescription   String         @default("") @db.Text
  emotionalBoundaries        Json           @default("[]")

  /// Brand Operating System — creative patterns
  hookStyles        Json            @default("[]")
  narrativeStyles   Json            @default("[]")
  persuasionStyle   PersuasionStyle @default(DIRECT)

  /// Brand Operating System — visual language (future image workflows)
  visualStyle        String @default("") @db.Text
  colorPhilosophy    String @default("") @db.Text
  compositionStyle   String @default("") @db.Text
  textureFocus       String @default("") @db.Text
  lightingStyle      String @default("") @db.Text

  updatedAt DateTime @updatedAt
}

/// Per-client service / quality contract (1:1).
model ServiceBlueprint {
  id       String @id @default(cuid())
  clientId String @unique
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  templateType      ServiceBlueprintTemplateType
  activeServices    Json
  qualityThreshold  Float
  approvalRequired  Boolean

  @@index([templateType])
}

// ---------------------------------------------------------------------------
// Brief & workflow tasks
// ---------------------------------------------------------------------------

model Brief {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title                   String
  businessObjective       String   @db.Text
  communicationObjective  String   @db.Text
  targetAudience          String   @db.Text
  keyMessage              String   @db.Text
  deliverablesRequested   Json
  tone                    String
  constraints             Json
  deadline                DateTime
  createdAt               DateTime @default(now())

  tasks Task[]

  @@index([clientId])
  @@index([createdAt])
}

/// Unit of orchestrated work within a Brief. Dependencies form a DAG enforced by the orchestrator.
model Task {
  id     String @id @default(cuid())
  briefId String
  brief   Brief  @relation(fields: [briefId], references: [id], onDelete: Cascade)

  stage          WorkflowStage
  /// Null for system stages (e.g. brief intake, export packaging) that do not invoke an agent role.
  agentType      AgentType?
  status         TaskStatus    @default(PENDING)
  requiresReview Boolean       @default(false)

  startedAt   DateTime?
  completedAt DateTime?

  /// Edges where THIS task is the successor: "this task depends on prerequisite(s)".
  dependencies TaskDependency[] @relation("TaskDependencyDependent")
  /// Edges where THIS task is the prerequisite: other tasks wait on this one.
  dependents   TaskDependency[] @relation("TaskDependencyPrerequisite")

  artifacts   Artifact[]
  reviewItems ReviewItem[]
  agentRuns   AgentRun[]

  @@index([briefId])
  @@index([briefId, stage])
  @@index([briefId, status])
  @@index([status])
}

/// Explicit prerequisite edge: `taskId` cannot proceed until `dependsOnTaskId` satisfies orchestrator rules.
model TaskDependency {
  id              String @id @default(cuid())
  taskId          String
  dependsOnTaskId String

  task          Task @relation("TaskDependencyDependent", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("TaskDependencyPrerequisite", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([dependsOnTaskId])
}

// ---------------------------------------------------------------------------
// Artifacts & review
// ---------------------------------------------------------------------------

model Artifact {
  id     String @id @default(cuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  type    ArtifactType
  content Json
  version Int
  createdAt DateTime @default(now())

  reviewItems     ReviewItem[]
  artifactOutcomes ArtifactOutcome[]

  @@unique([taskId, type, version])
  @@index([taskId])
  @@index([taskId, type])
}

/// Per-client rolling stats for Creative Canon framework ids (string keys, not FK to a Framework table).
model FrameworkPerformance {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  frameworkId String

  timesUsed                  Int      @default(0)
  approvals                  Int      @default(0)
  revisions                  Int      @default(0)
  rejections                 Int      @default(0)
  stillWeakAfterRegenCount   Int      @default(0)
  lastUsedAt                 DateTime @default(now())

  @@unique([clientId, frameworkId])
  @@index([clientId])
  @@index([frameworkId])
}

model ArtifactOutcome {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  artifactId String
  artifact   Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  frameworkIds         Json
  outcome                ArtifactOutcomeType
  stillWeakAfterRegen    Boolean  @default(false)
  createdAt              DateTime @default(now())

  @@index([clientId])
  @@index([artifactId])
  @@index([clientId, createdAt])
}

model ReviewItem {
  id         String @id @default(cuid())
  taskId     String
  artifactId String?
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  artifact   Artifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  status   ReviewStatus @default(PENDING)
  feedback String       @db.Text
  /// Until auth ships: founder-supplied label (e.g. display name) for attribution.
  reviewerLabel  String?
  reviewerSource String   @default("studio")

  createdAt DateTime    @default(now())

  @@index([taskId])
  @@index([taskId, status])
  @@index([artifactId])
}

// ---------------------------------------------------------------------------
// Agent execution audit trail
// ---------------------------------------------------------------------------

model AgentRun {
  id     String @id @default(cuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  agentType AgentType
  input     Json
  output    Json
  /// Wall-clock duration of the run in milliseconds (nullable if run did not complete).
  duration  Int?
  /// Provider id, model, repair path, fallback flags, etc. (keeps output JSON artifact-focused).
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([taskId, createdAt])
  @@index([agentType])
}
